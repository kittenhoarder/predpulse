# Base URL for metadata, sitemap, and OG images
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: enable live orderbook depth data (Polymarket + Kalshi)
# ENABLE_ORDERBOOK_DEPTH=1

# Optional: enable smart money / top holders data (Polymarket only)
# ENABLE_SMART_MONEY=1

# Optional: custom path for persistent operator-index snapshots/outcomes store
# INDEX_STORE_PATH=./.predpulse/index-store.json

# Optional: set to "false" to disable hero section and compact pulse cards
# NEXT_PUBLIC_HERO_ENABLED=true
